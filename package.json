{
  "name": "@zixinit/vue-wangeditor-plus",
  "version": "0.1.0",
  "description": "A Vue 3 WangEditor wrapper with source editing, image sizing, attachment upload, and shared upload progress.",
  "type": "module",
  "main": "./dist/vue-wangeditor-plus.umd.cjs",
  "module": "./dist/vue-wangeditor-plus.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-wangeditor-plus.js",
      "require": "./dist/vue-wangeditor-plus.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit",
    "pack:local": "pnpm build && pnpm pack"
  },
  "peerDependencies": {
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "vue": "^3.4.0 || ^3.5.0"
  },
  "dependencies": {
    "codemirror": "5.65.21"
  },
  "devDependencies": {
    "@types/codemirror": "^5.60.17",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "vue-tsc": "^2.2.10",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12"
  }
}
